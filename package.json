{
  "name": "simplyflow-monorepo",
  "private": true,
  "version": "0.9.0",
  "description": "Workspace for SimplyFlow packages.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm --workspace @muze-labs/simplyflow run build",
    "build-dev": "npm --workspace @muze-labs/simplyflow run build-dev",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "dev": "watch 'npm run build-dev' ./packages & npx http-server ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muze-labs/simplyflow.git"
  },
  "keywords": [
    "UI",
    "components",
    "declarative",
    "reactive"
  ],
  "author": "auke@muze.nl",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/muze-labs/simplyflow/issues"
  },
  "homepage": "https://github.com/muze-labs/simplyflow#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "esbuild": "^0.24.2",
    "globals": "^15.13.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "watch": "^1.0.2"
  },
  "jest": {
    "transform": {},
    "testEnvironment": "jsdom"
  }
}
